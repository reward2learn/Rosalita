# Rosalita website — copy to .env.local and fill in values.
# Never commit .env.local or Google client_secret JSON files.

POSTGRES_URL=
ENCRYPTION_KEY=
SETUP_TOKEN=

# Google OAuth — optional when using DB-backed config (npm run seed:google-oauth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token

OPENAI_API_KEY=
# Chat model for SSE streaming (default gpt-4o-mini)
OPENAI_CHAT_MODEL=
# Model used when web search is enabled in /config (default gpt-4o-mini-search-preview)
OPENAI_WEB_SEARCH_MODEL=
# Canonical app URL (OAuth redirects, absolute links). Set in Vercel Production.
NEXT_PUBLIC_APP_URL=https://rosalita-business-review.vercel.app

