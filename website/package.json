{
  "name": "redruby-website",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "zenstack generate --schema zenstack/schema.zmodel && next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "zen:generate": "zenstack generate --schema zenstack/schema.zmodel",
    "enforce:redux": "node scripts/enforce-redux.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "generate:review-fallbacks": "bun run scripts/generate-review-part-fallbacks.ts",
    "seed": "bun run scripts/seed-from-sources.ts",
    "seed:google-oauth": "bun run scripts/seed-google-oauth.ts",
    "worker:pdf": "node scripts/pdf-worker.js",
    "postinstall": "node scripts/create_job_queue.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@mui/material-nextjs": "^9.1.1",
    "@neondatabase/serverless": "^0.10.0",
    "@prisma/client": "6.12.0",
    "@reduxjs/toolkit": "^2.6.0",
    "@sparticuz/chromium": "^133.0.0",
    "@zenstackhq/runtime": "2.22.3",
    "chart.js": "^4.5.1",
    "jose": "^6.0.0",
    "next": "^16.0.0",
    "puppeteer-core": "^24.43.1",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-redux": "^9.2.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "1.51.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.18.0",
    "happy-dom": "^16.7.0",
    "prisma": "6.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zenstack": "^2.11.0"
  },
  "overrides": {
    "prisma": "6.12.0",
    "@prisma/client": "6.12.0"
  }
}
